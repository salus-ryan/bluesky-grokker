# Bluesky credentials
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_PASSWORD=your-app-password

# Database
DATABASE_URL=postgresql://grokker:grokker@localhost:5432/bluesky_grokker

# Redis
REDIS_URL=redis://localhost:6379/0

# API keys (set whichever provider you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Embedding config
EMBEDDING_PROVIDER=              # defaults to LLM_PROVIDER; set separately if needed
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# LLM provider: "openai" | "anthropic" | "google" | "openrouter" | "ollama"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Agent
AGENT_ENABLED=false
AGENT_LOOP_INTERVAL=30

# Processing
BATCH_SIZE=50
MAX_CONCURRENT_EMBEDS=10

# Swarm (multi-model reasoning – MOTL-inspired)
SWARM_ENABLED=false              # set to true to fan out queries to all configured providers
SWARM_STRATEGY=all               # "all" | "fastest" | "consensus"
SWARM_TIMEOUT_MS=30000
SWARM_MAX_RETRIES=1
SWARM_MERGE_THRESHOLD=0.7

# Warm-up (verify provider connectivity on startup)
WARMUP_ENABLED=true
